{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "declaration": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "lib": ["ES2022", "DOM"],
    "resolveJsonModule": true
  },
  "include": ["src", "test"],
  "exclude": ["dist", "contract"]
}
